# ==============================================================================
# HELIX - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in the values to transition the project
# from mock development mode to live testnet/mainnet execution.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Ports & Server Configuration
# ------------------------------------------------------------------------------
# Ports on which the Node/TypeScript microservices listen.
COMPILER_PORT=8081
BACKTEST_PORT=8082
INDEXER_PORT=8090

# ------------------------------------------------------------------------------
# 2. Sui Blockchain Configuration
# ------------------------------------------------------------------------------
# HTTP URL for Sui RPC queries.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# WebSocket URL for Sui RPC event subscriptions (used by the live indexer stream).
SUI_WS_RPC_URL=wss://fullnode.testnet.sui.io:443

# The deployed HELIX Package ID.
HELIX_PACKAGE_ID=0xYOUR_DEPLOYED_HELIX_PACKAGE_ID_HERE

# The actual DeepBook Predict package address on testnet/mainnet.
# Used to replace imports/dependencies in the Move contracts.
PREDICT_PACKAGE_ID=0xPREDICT_PACKAGE_ID_ON_SUI

# The active deployer key pair / seed phrase if executing transactions from backend.
SUI_DEPLOYER_PRIVATE_KEY=suiprivkey1...

# ------------------------------------------------------------------------------
# 3. Trusted Execution Environment (TEE) Config
# ------------------------------------------------------------------------------
# Enforces real TEE remote attestation generation instead of HMAC mock signatures.
# 1 = Enable real TEE enclave flows, 0 = Use local dev mock signing.
HELIX_REAL_TEE=0

# Enclave private key used to HMAC-sign mock attestations during development,
# or the path to the enclave's AWS KMS key ARN in production.
HELIX_ENCLAVE_KEY=helix-mock-enclave-key

# ------------------------------------------------------------------------------
# 4. External Data Feeds (Oracle & Storage)
# ------------------------------------------------------------------------------
# Real-time options pricing and volatility surface data.
# Replaces 'tee/src/shared/mockOracle.ts'.
BLOCK_SCHOLES_API_URL=https://api.blockscholes.com/v1
BLOCK_SCHOLES_API_KEY=your_block_scholes_api_key_here

# Pyth Network API for asset spot prices.
PYTH_API_URL=https://hermes.pyth.network

# Decentralized storage endpoints for saving backtest results and equity curves.
# Replaces 'tee/src/shared/mockWalrus.ts'.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ------------------------------------------------------------------------------
# 5. Indexer Storage Configuration
# ------------------------------------------------------------------------------
# PostgreSQL database connection string.
# Replaces the in-memory Map structure in 'services/indexer/src/store.ts'.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helix_indexer_db
