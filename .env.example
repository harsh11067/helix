# ==============================================================================
# HELIX - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in the values to transition the project
# from mock development mode to live testnet/mainnet execution.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Ports & Server Configuration
# ------------------------------------------------------------------------------
# Ports on which the Node/TypeScript microservices listen.
COMPILER_PORT=8081
BACKTEST_PORT=8082
INDEXER_PORT=8090

# ------------------------------------------------------------------------------
# 2. Sui Blockchain Configuration
# ------------------------------------------------------------------------------
# HTTP URL for Sui RPC queries.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# WebSocket URL for Sui RPC event subscriptions (used by the live indexer stream).
SUI_WS_RPC_URL=wss://fullnode.testnet.sui.io:443

# The deployed HELIX Package ID.
HELIX_PACKAGE_ID=0xYOUR_DEPLOYED_HELIX_PACKAGE_ID_HERE

# The actual DeepBook Predict package address on testnet/mainnet.
# Used to replace imports/dependencies in the Move contracts.
PREDICT_PACKAGE_ID=0xPREDICT_PACKAGE_ID_ON_SUI

# The active deployer key pair / seed phrase if executing transactions from backend.
SUI_DEPLOYER_PRIVATE_KEY=suiprivkey1...

# ------------------------------------------------------------------------------
# 3. Trusted Execution Environment (TEE) Config
# ------------------------------------------------------------------------------
# Enforces real TEE remote attestation generation instead of HMAC mock signatures.
# 1 = Enable real TEE enclave flows, 0 = Use local dev mock signing.
HELIX_REAL_TEE=0

# Enclave private key used to HMAC-sign mock attestations during development,
# or the path to the enclave's AWS KMS key ARN in production.
HELIX_ENCLAVE_KEY=helix-mock-enclave-key

# ------------------------------------------------------------------------------
# 4. External Data Feeds (Oracle & Storage)
# ------------------------------------------------------------------------------
# Real-time options pricing and volatility surface data.
# Replaces 'tee/src/shared/mockOracle.ts'.
BLOCK_SCHOLES_API_URL=https://api.blockscholes.com/v1
BLOCK_SCHOLES_API_KEY=your_block_scholes_api_key_here

# Pyth Network API for asset spot prices.
PYTH_API_URL=https://hermes.pyth.network

# Decentralized storage endpoints for saving backtest results and equity curves.
# Replaces 'tee/src/shared/mockWalrus.ts'.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ------------------------------------------------------------------------------
# 5. Indexer Storage Configuration
# ------------------------------------------------------------------------------
# PostgreSQL database connection string.
# Replaces the in-memory Map structure in 'services/indexer/src/store.ts'.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helix_indexer_db

# ------------------------------------------------------------------------------
# 6. LIVE testnet addresses — verified on-chain (zkLogin + Seal feature work)
# ------------------------------------------------------------------------------
# These are the REAL, currently-deployed values the frontend reads (mirrored in
# tistu/js/app.js CFG, tistu/js/seal.js, and the app.html <script> config block).
# Treat this section as the source of truth when re-wiring or redeploying.

# HELIX package — published (v1), upgraded v2 (add seal_policy), upgraded v3 (add
# marketplace::copy_for_thesis for the cross-wallet copier path). THREE ids matter:
#   ORIGINAL (v1) = Seal encryption identity namespace + SessionKey packageId +
#                   the type-origin for v1 types (e.g. CopyRelationship, StrategyObject).
#   LATEST   (v3) = all moveCall targets (copy_for_thesis lives ONLY here; seal_approve* too).
#   SEAL_TYPE_ORIGIN (v2) = type-origin of seal_policy::ThesisAttached → event queries
#                   (SEAL_EVENT_TYPE) use this, NOT v3, even though v3 also has the module.
HELIX_PACKAGE_ORIGINAL=0xdc4b27696494c3c5f54513b19781686f7354a7b09f7ccf2285f7b843c7add2b3
HELIX_PACKAGE_LATEST=0xbcd36b706472927ab7865a2ba31e343bfdc3c24312f39a9cb79cde88faaa45e0
HELIX_PACKAGE_SEAL_TYPE_ORIGIN=0x96b36ef86f445b525eccaa5410a2c6cebe6c6dff85c86fbfee9914581b0ad391
HELIX_UPGRADE_CAP=0x1b7f5f6776905e738032601dd1cc016ff083b4fcbec03e879686a26415e1d7eb
# upgrade history: v2 add seal_policy (0x96b3) · v3 add copy_for_thesis (0x360d, tx BMmj4MRZRWQwewcrbxbtSZxDk3xmxQMxCPLTU55meZ7b)
#   · v4 fix seal_approve_copier to drop StrategyObject (0xbcd3, tx BfLv838F5Ru64DnHcY4rvYWQrPt5FXMyeoEVtBMbYDBC) — current LATEST

# DeepBook Predict (pinned predict-testnet-4-16).
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
PREDICT_SERVER=https://predict-server.testnet.mystenlabs.com

# --- Feature 1: zkLogin (Sign in with Google → self-custodial Sui address) ---
# Powered by ENOKI (Mysten's hosted prover + salt). WHY: the public Mysten prover
# allow-lists OAuth audiences, so a custom Google client id returns
# 400 "audience … is not supported"; the devnet prover accepts any audience but
# emits TEST-circuit proofs that fail testnet's verifier ("Groth16 proof verify
# failed"). Enoki proves against the testnet circuit for YOUR registered client id.
#
# Google OAuth *Web* client id (the OAuth redirect uses it). Register redirect URIs
# that match the page exactly, e.g. https://<app-host>/app.html + localhost.
HELIX_GOOGLE_CLIENT_ID=336366260371-t44qbp4r54kls5fk98nhi439tq9681ou.apps.googleusercontent.com
# Enoki PUBLIC API key (enoki_public_…) from https://portal.enoki.mystenlabs.com .
# Domain-restricted → safe in the frontend. In the Enoki portal: create a project,
# copy the public key, add Google as an auth provider with the SAME client id above,
# and allow-list your app origin(s). Set this in app.html as window.HELIX_ENOKI_KEY.
HELIX_ENOKI_KEY=enoki_public_e357a56724a84818d4470a37d189372c
HELIX_ENOKI_NETWORK=testnet

# --- Feature 2: Seal (encrypted private thesis) + Walrus storage ---
# 1-of-2 Mysten testnet key servers (resolved at runtime via getAllowlistedKeyServers).
SEAL_THRESHOLD=1
SEAL_KEYSERVER_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
SEAL_KEYSERVER_2=0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8
